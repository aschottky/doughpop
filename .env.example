# DoughPop Environment Variables
# Copy this file to .env and fill in your values

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get your publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── GCP Checkout Function ───────────────────────────────────────────────────
# URL of your deployed Google Cloud Function (optional - needed for subscriptions)
VITE_CHECKOUT_API_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/createCheckoutSession

# ─── GCP Cloud Function env vars (set these in GCP console, NOT here) ────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SITE_URL=https://doughpop.app
